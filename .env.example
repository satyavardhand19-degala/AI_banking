# ── Vaani AI Data Intelligence — Environment Configuration ──

# AI Engine (Optional — enables Pandas Agent + AI SQL + AI Summaries)
# Without this key, the system uses Rule Engine mode (regex-based SQL only)
OPENAI_API_KEY=

# Voice — Sarvam AI (Optional — enables STT/TTS voice features)
# Without this key, STT returns demo text and TTS is disabled
SARVAM_API_KEY=
SARVAM_STT_MODEL=saarika:v2
SARVAM_TTS_MODEL=bulbul:v1
SARVAM_TTS_VOICE=meera

# Database (defaults work for local development)
USE_LOCAL_DB=true
SQLITE_DB_PATH=local_vault.db

# Supabase (Only needed if USE_LOCAL_DB=false)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_HOST=db.YOUR_PROJECT_REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-database-password

# App
ALLOWED_ORIGINS=*
APP_ENV=development
